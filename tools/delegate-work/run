#!/usr/bin/env -S nu --stdin

# TODO: docs
# TODO: tests

use std/log

use ../../src/agent-loop.nu
use ../../src/context

export def main [] {
  let input = $in | from json
  let config = $input.config
  let params = $input.tool_call.function.arguments

  mut message = {}

  agent-loop run {
    config: $config
    persona: $params.worker
    manager_job_id: (job id)
    initial_context: (
      {
        role: "user"
        content: $params.task
      }
      | context append message (context initial $config $params.worker)
    )
    history_path: ""
  }

  loop {
    $message = job recv
    # TODO: add timeout (configurable per agent type?) to manage llms in loops
    #       if it times out w/o a message assume something is broken
    #       The timeout will have to be long enough to include _loading_ the model, so maybe an intelligent thing can know
    #       if the model is loaded before it "starts" the timer...

    match ($message.context | context get state) {
      "awaiting-model" => {
        $message
        | job send $message.reply_to_job_id
        # TODO: the agent-loop should handle this awaiting
      }

      "awaiting-controller-input" => {
        break
      }
    }
  }

  $message.context.messages
  | last
  | get content
}
