#!/usr/bin/env -S nu --stdin

def insert [
  path: string
  after: int
  new_lines: string
]: nothing -> string {
  let lines = open --raw $path
  | lines

  $lines
  | take $after
  | append $new_lines
  | append ($lines | skip $after)
  | str join "\n"
}

# def overwrite [
