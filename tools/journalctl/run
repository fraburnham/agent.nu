#!/usr/bin/env -S nu --stdin

export def main []: string -> string {
  let input = $in | from json
  let params = $input.tool_call.function.arguments

  let journalctl_flags = $params.flags?
  | default ""
  | split row " "

  let grep_expression = $params.grep?
  | default ""

  if ($params.flags | is-empty) {
    journalctl --no-pager
  } else {
    journalctl --no-pager ...($journalctl_flags)
  }
  | do { ||
    if ($grep_expression | is-empty) {
      $in
    } else {
      $in
      | grep $grep_expression
      | complete
      | get stdout
    }
  }
}
